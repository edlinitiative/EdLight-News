# Don't upload local build caches or dev server outputs
.next
.turbo
node_modules

# Exclude compiled dist for generator/publisher/renderer/scraper (not needed by web)
# packages/types/dist and packages/firebase/dist are committed and must be present
# so tsc can resolve @edlight-news/types and @edlight-news/firebase
packages/generator/dist
packages/publisher/dist
packages/renderer/dist
packages/scraper/dist

# Worker app is not deployed to Vercel (it runs separately)
apps/worker

# Secrets
.env
.env.local
