{
  "name": "@edlight-news/firebase",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "node -e \"const fs=require('fs'),path=require('path');const d='../types/dist';console.log('CWD:',process.cwd());console.log('types/dist exists:',fs.existsSync(d));console.log('index.d.ts:',fs.existsSync(d+'/index.d.ts'));const nm=path.resolve('node_modules/@edlight-news/types');console.log('node_modules link:',fs.existsSync(nm));\" && tsc -b",
    "typecheck": "tsc -b --noEmit",
    "dev": "tsc -b --watch"
  },
  "dependencies": {
    "@edlight-news/types": "workspace:*",
    "firebase-admin": "^12.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  }
}
