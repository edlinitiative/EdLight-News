{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "jsx": "react-jsx",
    "lib": ["ES2023", "DOM"],
    "types": ["node", "react"],
    // composite=false: this is a secondary build that overlays JSX templates
    // on top of the primary Node build. Don't emit a buildinfo conflict.
    "composite": false
  },
  "include": ["src/**/*"],
  "exclude": ["**/*.test.ts", "**/*.test.tsx", "dist", "node_modules"]
}
