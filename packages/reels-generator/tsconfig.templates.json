{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist/templates",
    "rootDir": "./src/templates",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "jsx": "react-jsx",
