# dependencies
node_modules
.pnpm-store

# build outputs
dist
# keep types/dist committed so Vercel always has it without race conditions
!packages/types/dist/
.next
.turbo
out
*.tsbuildinfo
# compiled outputs accidentally ending up in src/
packages/*/src/*.js
packages/*/src/*.d.ts
packages/*/src/*.map

# env secrets
.env
.env.local
.env.*.local

# misc
*.log
nohup.out

.vercel
.env*.local
