# dependencies
node_modules
.pnpm-store

# build outputs
dist
.next
.turbo
out
*.tsbuildinfo
# compiled outputs accidentally ending up in src/
packages/*/src/*.js
packages/*/src/*.d.ts
packages/*/src/*.map
packages/*/src/**/*.js
packages/*/src/**/*.d.ts
packages/*/src/**/*.map
apps/*/src/**/*.js
apps/*/src/**/*.d.ts
apps/*/src/**/*.map
# compiled config files at app root (e.g. tailwind.config.js from .ts)
apps/*/*.js
apps/*/*.d.ts
apps/*/*.map
!apps/*/next.config.js
!apps/*/postcss.config.js

# env secrets
.env
.env.local
.env.*.local

# misc
*.log
nohup.out
history-illustrations-audit.json
web-image-cache.json

.vercel
.env*.local
