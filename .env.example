# Firebase Admin SDK — Service Account credentials
# Get these from Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Paste the private key exactly as-is (including -----BEGIN PRIVATE KEY----- lines).
# Vercel stores it safely; no need to escape newlines.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# Google Gemini API key (only needed by the worker, not the web app)
GEMINI_API_KEY=AIzaSy...

# ── LLM Provider Selection ────────────────────────────────────────────────────
# Which LLM to use for content generation. Options:
#   gemini   — Google Gemini (default). Needs GEMINI_API_KEY. Also used for image gen.
#   groq     — Groq (FREE tier). Needs GROQ_API_KEY. Very fast inference.
#   mistral  — Mistral AI (FREE tier). Needs MISTRAL_API_KEY. Excellent for French.
#   openrouter — OpenRouter (has free model variants). Needs OPENROUTER_API_KEY.
#   openai   — OpenAI. Needs OPENAI_API_KEY. Paid only.
#   anthropic — Anthropic. Needs ANTHROPIC_API_KEY. Paid only.
#
# To get the pipeline working for FREE (no Gemini required):
#   1. Get a free Groq API key → https://console.groq.com/keys
#      OR a free Mistral API key → https://console.mistral.ai/
#   2. Set LLM_PROVIDER=groq (or mistral) and the matching API key below.
#   3. Image generation falls back to Unsplash / branded gradient when Gemini is off.
LLM_PROVIDER=gemini

# Optional: use a different provider/model for the reviewer pass
# LLM_REVIEWER_PROVIDER=groq
# LLM_REVIEWER_MODEL=llama-3.3-70b-versatile

# ── Free LLM API keys ────────────────────────────────────────────────────────
# Groq — https://console.groq.com/keys  (free: 30 RPM, 12K TPM on 70B)
# Models: llama-3.3-70b-versatile, llama-3.1-8b-instant, meta-llama/llama-4-scout-17b-16e-instruct
# GROQ_API_KEY=gsk_...

# Mistral — https://console.mistral.ai/  (free tier available, great for French)
# Models: mistral-small-latest, mistral-large-latest
# MISTRAL_API_KEY=...

# OpenRouter — https://openrouter.ai/keys  (free ":free" model variants, 20 RPM)
# Models: meta-llama/llama-3.3-70b-instruct:free, google/gemma-2-9b-it:free
# OPENROUTER_API_KEY=sk-or-...

# ── Image sourcing API keys ───────────────────────────────────────────────────
# The tiered image pipeline searches: Official Flickr → Wikimedia Commons →
# Library of Congress → Unsplash → Flickr CC. Most work without keys.
#
# Unsplash — https://unsplash.com/developers  (free: 50 req/hour)
# Used for high-quality stock photo fallback
Unsplash_ACCESS_KEY=your_access_key
Unsplash_Secret_Key=your_secret_key
Unsplash_Application_ID=your_app_id

# Flickr — https://www.flickr.com/services/api/  (free: 3600 req/hour)
# Used to search official government Flickr accounts (White House, UN, etc.)
# FLICKR_API_KEY=your_flickr_api_key

# Library of Congress — no API key needed (loc.gov/apis)
# Brave Search — https://brave.com/search/api/  (free: 2000 queries/month)
# BRAVE_SEARCH_API_KEY=BSA...

# Firebase Storage bucket name (used by the worker to upload article images).
# Format: <project-id>.firebasestorage.app (newer) or <project-id>.appspot.com (older)
FIREBASE_STORAGE_BUCKET=edlight-news.firebasestorage.app

# ── Google Custom Search (used by enrich:history-sources job) ─────────────────
GOOGLE_CSE_API_KEY=AIzaSy...
GOOGLE_CSE_CX=abc123:xyz

# ── Worker tuning ─────────────────────────────────────────────────────────────
# Max raw_items to process per tick (each does an HTTP fetch + optional Gemini call)
PROCESS_BATCH_LIMIT=10

# Max items to generate branded card images for per tick (each launches Chromium)
IMAGE_BATCH_LIMIT=5

# How often the Cloud Run worker self-schedules (milliseconds). Default: 30 min.
# GitHub Actions pipeline.yml also fires every 30 min independently.
TICK_INTERVAL_MS=1800000

# ── Instagram publishing (Graph API) ──────────────────────────────────────────
# Without these two vars the IG pipeline runs in dry-run mode (HTML + manifest
# saved to /tmp/ig_exports/ instead of posting). See docs/copilot.md for details.
#
# 1. Go to https://developers.facebook.com/tools/explorer/
# 2. Select your app, generate a User Token with permissions:
#      instagram_basic, instagram_content_publish, pages_read_engagement
# 3. Query: GET /me/accounts?fields=id,name,instagram_business_account
#    → the instagram_business_account.id value is your IG_USER_ID.
# 4. Exchange the short-lived token for a permanent Page Token (see README).
IG_ACCESS_TOKEN=EAAxxxxxxx...
IG_USER_ID=17841400000000000

# ── Web → Worker connection ───────────────────────────────────────────────────
# Full URL of the deployed worker (Cloud Run).
# Printed at the end of every successful deploy-worker.yml run.
WORKER_URL=https://edlight-news-worker-xxxx-uc.a.run.app

# ── Admin authentication ──────────────────────────────────────────────────────
# Password required to access the /admin section of the web app.
# Set this in Vercel Environment Variables. In local dev, if unset, admin
# pages are accessible without a password.
ADMIN_PASSWORD=your-secure-admin-password

# ── Cloud Run deployment (only needed for deploy-worker.yml) ──────────────────
# GCP service account key JSON with these IAM roles:
#   - Cloud Run Admin
#   - Artifact Registry Writer
#   - Service Account User
# Create: GCP Console → IAM → Service Accounts → Keys → Add Key → JSON
# Store the entire JSON content as the GCP_SA_KEY GitHub secret.
GCP_SA_KEY={"type":"service_account","project_id":"edlight-news",...}
