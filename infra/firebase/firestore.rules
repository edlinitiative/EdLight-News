rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default: deny all
    match /{document=**} {
      allow read, write: if false;
    }

    // Sources: admin only (server-side via Admin SDK bypasses rules)
    match /sources/{sourceId} {
      allow read: if true;
      allow write: if false;
    }

    // Raw items: server-only writes
    match /raw_items/{itemId} {
      allow read: if true;
      allow write: if false;
    }

    // Items: server-only writes
    match /items/{itemId} {
      allow read: if true;
      allow write: if false;
    }

    // Content versions: public read for published, server writes
    match /content_versions/{versionId} {
      allow read: if resource.data.status == 'published';
      allow write: if false;
    }

    // Assets: public read
    match /assets/{assetId} {
      allow read: if true;
      allow write: if false;
    }

    // Publish queue: server-only
    match /publish_queue/{entryId} {
      allow read, write: if false;
    }

    // Metrics: server-only
    match /metrics/{metricId} {
      allow read, write: if false;
    }

    // Utility sources: public read, server writes
    match /utility_sources/{sourceId} {
      allow read: if true;
      allow write: if false;
    }

    // Utility queue: server-only
    match /utility_queue/{entryId} {
      allow read, write: if false;
    }

    // ── Student Intelligence Platform collections ──────────────────────────

    // Universities: public read, server-only writes
    match /universities/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Scholarships: public read, server-only writes
    match /scholarships/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Haiti education calendar: public read, server-only writes
    match /haiti_education_calendar/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Pathways: public read, server-only writes
    match /pathways/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Dataset jobs: server-only
    match /dataset_jobs/{docId} {
      allow read, write: if false;
    }

    // Contributor profiles: server-only
    match /contributor_profiles/{docId} {
      allow read, write: if false;
    }

    // Drafts: server-only
    match /drafts/{docId} {
      allow read, write: if false;
    }

    // ── Haiti History Almanac collections ───────────────────────────────

    // Haiti history almanac: public read, server-only writes
    match /haiti_history_almanac/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Haiti holidays: public read, server-only writes
    match /haiti_holidays/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // History publish log: server-only
    match /history_publish_log/{docId} {
      allow read, write: if false;
    }
  }
}
